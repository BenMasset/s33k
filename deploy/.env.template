# s33k deploy environment template.
#
# Copy this file to deploy/.env and fill in real values:
#   cp deploy/.env.template deploy/.env
#
# Every value below is a PLACEHOLDER or a clearly-marked throwaway. The two that
# you MUST regenerate before any real or internet-facing use are SECRET and
# APIKEY (see how to generate them in the Auth block). docker compose reads this
# file automatically when you run `docker compose -f deploy/docker-compose.yml`.

# =============================================================================
# Auth (s33k login + API)
# =============================================================================
# USER_NAME: the admin login username for the s33k web UI.
USER_NAME=admin

# PASSWORD: the admin login password. CHANGE THIS for real use.
PASSWORD=change-me-please

# SECRET: encryption key s33k uses to encrypt stored API keys (Serper, SMTP,
# Search Console) and to sign sessions. REGENERATE a fresh value, e.g.:
#   openssl rand -hex 34
# Do NOT ship the placeholder below to production.
SECRET=REGENERATE_ME_openssl_rand_hex_34

# APIKEY: the Bearer token the REST API and the MCP server authenticate with
# (S33K_API_KEY in the MCP config maps to this). REGENERATE a fresh value, e.g.:
#   openssl rand -hex 24
# Do NOT ship the placeholder below to production.
APIKEY=REGENERATE_ME_openssl_rand_hex_24

# SESSION_DURATION: login session length in hours.
SESSION_DURATION=24

# NEXT_PUBLIC_APP_URL: the public URL where s33k is reached. With the default
# port map this is http://localhost:8080. Set it to your real host in production.
NEXT_PUBLIC_APP_URL=http://localhost:8080

# =============================================================================
# SERP scraper (Serper is the day-one value path)
# =============================================================================
# NOTE: the scraper type and key are NOT read from env. s33k stores them
# (encrypted) in its own database. You set them ONCE in the web UI on first run:
#   s33k -> Settings -> Scraper -> select "Serper" and paste your key.
# The two lines below are documentation of what to enter there. Get a key at
# https://serper.dev (pay-as-you-go, ~$1 / 1000 lookups).
SCRAPER_TYPE=serper
SERPER_API_KEY=paste-your-serper-key-in-the-Settings-UI

# =============================================================================
# Analytics provider
# =============================================================================
# Which analytics backend s33k reads per-page traffic from.
#   umami  the owned, self-hosted engine in this compose (default, recommended)
#   lodd   legacy/dev option (closed third-party SaaS)
ANALYTICS_PROVIDER=umami

# -----------------------------------------------------------------------------
# Umami (the owned analytics engine running in this compose)
# -----------------------------------------------------------------------------
# UMAMI_BASE_URL: internal address of the umami service. Leave as-is; this is the
# in-network URL, NOT the host 8081 port.
UMAMI_BASE_URL=http://umami:3000

# Login s33k uses to read Umami. Defaults match Umami's first-run admin account
# (admin / umami). CHANGE the Umami admin password in the Umami UI for real use,
# then update UMAMI_PASSWORD here to match.
UMAMI_USERNAME=admin
UMAMI_PASSWORD=umami

# UMAMI_WEBSITE_ID: the id of the website you create in Umami.
# Get it from Umami -> Settings -> Websites -> (your site) -> id.
# Leave blank to have s33k match the website by domain name instead.
UMAMI_WEBSITE_ID=

# UMAMI_METRICS_TYPE: page-grouping metric, "url" (default) or "path".
UMAMI_METRICS_TYPE=url

# Optionally use a pre-issued Umami bearer token instead of username/password:
# UMAMI_API_KEY=

# -----------------------------------------------------------------------------
# Umami database (Postgres) credentials
# -----------------------------------------------------------------------------
# THROWAWAY defaults below. Set a strong UMAMI_DB_PASSWORD for real use.
UMAMI_DB_USER=umami
UMAMI_DB_PASSWORD=umami
UMAMI_DB_NAME=umami

# UMAMI_APP_SECRET: salt Umami uses to hash sessions. THROWAWAY default in the
# compose file; set a fresh value here for real use, e.g. openssl rand -hex 16.
UMAMI_APP_SECRET=s33k-umami-throwaway-secret-change-me

# =============================================================================
# Legacy Lodd provider (only read when ANALYTICS_PROVIDER=lodd)
# =============================================================================
# Closed third-party SaaS. Leave blank unless you switch ANALYTICS_PROVIDER=lodd.
# LODD_API_KEY is your Lodd API key; LODD_SITE is the site UUID to read.
LODD_API_KEY=
LODD_SITE=
LODD_BASE_URL=https://api.lodd.dev/v1

# =============================================================================
# Optional: Google Search Console (level 2, richer keyword data)
# =============================================================================
# Service-account credentials for GSC. Safe to leave blank; connect later.
SEARCH_CONSOLE_CLIENT_EMAIL=
SEARCH_CONSOLE_PRIVATE_KEY=
