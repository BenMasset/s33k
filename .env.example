# s33k environment configuration.
#
# Copy this file to .env and fill it in: cp .env.example .env
# Every value below is a safe placeholder. Replace the ones marked REQUIRED
# before you run s33k, and never commit your real .env (it is gitignored).
#
# Two of these are secrets you MUST regenerate, not copy from anywhere:
#   SECRET  -> openssl rand -hex 34
#   APIKEY  -> openssl rand -hex 24

# === Admin login (REQUIRED) =================================================
# The single admin account for the web UI and the username/password the app
# uses internally. Use USER_NAME, not USER: many shells already export USER as
# your operating-system username, which would silently override a bare USER.
USER_NAME=admin
PASSWORD=change-me-to-a-strong-password

# === Secrets (REQUIRED, regenerate both) ====================================
# SECRET encrypts stored credentials and signs the login session.
#   Generate with: openssl rand -hex 34
SECRET=replace-with-openssl-rand-hex-34
# APIKEY is the Bearer token for the REST API and the MCP server. The value you
# put here is the same value the MCP server reads as S33K_API_KEY.
#   Generate with: openssl rand -hex 24
APIKEY=replace-with-openssl-rand-hex-24

# Login session length, in hours. Optional, defaults to 24 if unset.
SESSION_DURATION=24

# === Database (Postgres in prod, SQLite locally) ============================
# DATABASE_URL is THE switch that selects the database. When set, s33k uses
# Postgres (the production database). When UNSET, s33k falls back to a local
# SQLite file (good for dev). Always set this in production: SQLite on a mounted
# volume is unreliable in the standalone runtime (see CLAUDE.md / DEPLOY.md).
#   Example: postgresql://user:password@host:5432/s33k
# DATABASE_URL=
# DATABASE_PATH: absolute path for the SQLite file (SQLite branch only, ignored
# under Postgres). Optional; defaults to ./data/database.sqlite.
# DATABASE_PATH=

# Public URL where this s33k instance is reached in a browser. Used to build
# OAuth redirect URLs behind a reverse proxy. Optional for local dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PORT the s33k web server listens on. Optional, defaults to 3000.
# PORT=3000

# === SERP scraper (REQUIRED for live rankings) ==============================
# s33k scrapes live Google rankings. Serper is the day-one source: one key,
# results in about two minutes. Get a key at https://serper.dev.
# The scraper can also be set in the UI (stored encrypted in the database);
# these env values are the fallback used when the database has none.
SCRAPER_TYPE=serper
SERPER_API_KEY=your-serper-api-key
# SCAPING_API is the key used by scrapers other than Serper (for example
# scrapingrobot or scrapingant). Optional; only set it if SCRAPER_TYPE is one
# of those. The misspelling matches the upstream SerpBear variable name.
# SCAPING_API=
# SCREENSHOT_API is an optional key for a screenshot service. Optional.
# SCREENSHOT_API=

# === Analytics provider (per-page traffic for the scoreboard join) ==========
# s33k OWNS its analytics via self-hosted Umami (open source, MIT). Umami is the
# standalone, owned analytics engine; Lodd is a legacy/dev option (closed SaaS).
# ANALYTICS_PROVIDER selects the backend: "umami" (default) or "lodd".
ANALYTICS_PROVIDER=umami

# --- Umami (self-hosted v2): the owned analytics engine. ---
# Required when ANALYTICS_PROVIDER=umami.
# UMAMI_BASE_URL: base URL of your Umami instance (with or without a trailing /api).
# UMAMI_WEBSITE_ID: the Umami website id to read. Optional. If unset, s33k looks
#   it up from GET /api/websites by matching the domain.
# Auth: provide EITHER UMAMI_API_KEY (a pre-issued bearer token) OR
#   UMAMI_USERNAME + UMAMI_PASSWORD (s33k logs in via POST /api/auth/login).
# UMAMI_METRICS_TYPE: page-grouping metric, "url" (default) or "path". Optional.
# UMAMI_BASE_URL=https://analytics.example.com
# UMAMI_WEBSITE_ID=
# UMAMI_API_KEY=
# UMAMI_USERNAME=
# UMAMI_PASSWORD=
# UMAMI_METRICS_TYPE=url

# --- Lodd Analytics (legacy/dev provider; closed third-party SaaS). ---
# Used only when ANALYTICS_PROVIDER=lodd. Optional otherwise.
# LODD_API_KEY is your Lodd API key. LODD_SITE is the site UUID to read.
# LODD_BASE_URL defaults to https://api.lodd.dev/v1 when unset.
# LODD_SITE_DOMAIN is the domain that LODD_SITE belongs to. Optional. Set it to
# skip the /sites lookup, or when one Lodd key serves multiple sites.
# LODD_API_KEY=
# LODD_SITE=
# LODD_BASE_URL=https://api.lodd.dev/v1
# LODD_SITE_DOMAIN=

# === Google Search Console (optional) =======================================
# Connects GSC for the get_insight tool (top pages, keywords, countries, stats).
#
# Preferred: click-to-authorize OAuth. Create an OAuth 2.0 Web client in Google
# Cloud, add ${NEXT_PUBLIC_APP_URL}/api/searchconsole/callback as an authorized
# redirect URI, then set the two vars below. Users (and you, for your own domain)
# connect with one click via the connect_search_console MCP tool, no JSON pasting.
# Both must be set together, or the connect endpoint reports "not configured".
# GSC_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
# GSC_OAUTH_CLIENT_SECRET=your-oauth-client-secret
#
# Fallback: service-account credentials (still supported). Both must be set
# together, or leave both unset. Paste the private key as a single line with
# literal \n for newlines.
# SEARCH_CONSOLE_CLIENT_EMAIL=service-account@your-project.iam.gserviceaccount.com
# SEARCH_CONSOLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# === Proxy + rate limiting (optional) =======================================
# TRUSTED_PROXY_HOPS: how many trusted reverse proxies sit in front of s33k.
# It controls which X-Forwarded-For hop is trusted as the client IP for rate
# limiting; a wrong value lets clients spoof IPs and bypass the limiter. Default
# is 1 (Railway puts exactly one proxy in front). Cloudflare -> Railway = 2.
# TRUSTED_PROXY_HOPS=1
# RATE_LIMIT_GLOBAL_MAX: hard ceiling on total requests per window across all
# keys (anti-flood backstop). Optional, defaults to 100000. Set 0 to disable.
# RATE_LIMIT_GLOBAL_MAX=100000
# COLLECT_RATE_LIMIT: max /api/collect ingest requests per IP per window.
# Optional, defaults to 600. COLLECT_RATE_WINDOW_MS defaults to 60000 (1 min).
# COLLECT_RATE_LIMIT=600
# COLLECT_RATE_WINDOW_MS=60000

# === AI-crawler ingest (optional, off by default) ===========================
# CRAWLER_INGEST_ENABLED gates the /api/crawler-hit ingest endpoint that records
# server-side AI-crawler hits (GPTBot, ClaudeBot, etc.). It is OFF unless set to
# the literal "true". Leave unset for the zero-config V1 (domain in, no feeder).
# CRAWLER_INGEST_ENABLED=false

# === Email (optional; invites + feature-request notices) ====================
# RESEND_API_KEY enables sending external/internal invite emails and feature-
# request notifications via Resend. Without it those features silently no-op
# (the rows are still created; no email goes out).
# RESEND_FROM_EMAIL is the From address; defaults to "s33k <noreply@invites.s33k.io>".
# The address must be on a domain/subdomain verified in Resend (invites.s33k.io).
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=s33k <noreply@invites.s33k.io>

# === Multi-tenant mode (optional, advanced) =================================
# Leave unset for the normal single-admin install. Set to true only if you are
# running the experimental per-tenant scoping described in MULTI_TENANT.md.
# MULTI_TENANT=false

# === Billing (per-unit Stripe subscription + 14-day no-credit-card trial) ===
# Per-unit model: $7 per site, 50 keywords per site, weekly rank checks, 14-day
# no-credit-card trial. The subscription quantity = the number of sites. Billing
# is ONLY active with MULTI_TENANT on. New accounts start the 14-day trial, then
# must subscribe to keep write features + rank scraping. With all of these unset
# the billing routes return a clean "billing not configured" error and never
# crash (local/dev safe). Set all three to go live.
# STRIPE_SECRET_KEY: your Stripe secret API key (sk_live_... or sk_test_...).
# STRIPE_WEBHOOK_SECRET: the signing secret (whsec_...) for the webhook endpoint
#   you add in the Stripe dashboard, pointing at /api/billing/webhook.
# STRIPE_PRICE_PER_SITE: the ONE recurring Stripe Price id (price_...) for $7 per
#   site / month. Checkout buys it with quantity = the number of sites.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PER_SITE=
